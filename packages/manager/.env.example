CLSSW_MANAGER_TOKEN=your-manager-token-here-min-8-chars
CLSSW_MANAGER_HOST=127.0.0.1
CLSSW_MANAGER_PORT=8443
CLSSW_MANAGER_DATA=./data
CLSSW_MANAGER_WEB_DIST=../web/dist
# Agent self-registration uses one-shot tickets issued by the
# /v1/manager/agents/onboarding-ticket endpoint (session-authed) — no
# shared secret to manage here.
CORS_ORIGIN=*
