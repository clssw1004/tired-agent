# tired-pc server configuration
# Copy this file to `.env` (same directory) and fill in real values.
# Lines starting with `#` are comments. `KEY=value` exports KEY into process.env.

# ── Required ─────────────────────────────────────────────────────────────────
# Bearer token clients must send on every request. Generate one with:
#   openssl rand -hex 16          # → 32-char hex (recommended)
# Must be at least 8 characters or the server refuses to start.
CLSSW_TOKEN=change-me-to-a-long-random-secret-at-least-8-chars

# ── Network ──────────────────────────────────────────────────────────────────
# TCP port to listen on.
PORT=8443
# Bind address. Use 127.0.0.1 for local-only, 0.0.0.0 to expose on the LAN.
HOST=127.0.0.1

# ── Storage ──────────────────────────────────────────────────────────────────
# Where the SQLite database and PTY session log files live.
CLSSW_DATA=./data

# Storage backend. One of: sqlite (default), mysql, postgres.
STORAGE_KIND=sqlite

# MySQL — used only when STORAGE_KIND=mysql. Uncomment to enable.
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=tired
# MYSQL_PASSWORD=
# MYSQL_DATABASE=tired_pc

# PostgreSQL — used only when STORAGE_KIND=postgres. Uncomment to enable.
# POSTGRES_CONNECTION_STRING=postgres://user:pass@localhost:5432/tired_pc

# ── CORS ─────────────────────────────────────────────────────────────────────
# Permissive CORS (allow any origin) is the default for local web dev.
# Set CLSSW_STRICT_CORS=1 in production to disable it and serve your own origin.
# CLSSW_STRICT_CORS=1
