# tired-pc · production-ready .env template
# ──────────────────────────────────────────
# 1. cp packages/server/.env.production.example packages/server/.env
# 2. Review every value. At minimum, generate YOUR OWN token (step 4 below).
# 3. Set HOST to 127.0.0.1 if you'll front it with nginx (recommended),
#    or 0.0.0.0 only if you trust the network — better keep it loopback.
# 4. Generate a fresh token:
#       node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#    and paste it into CLSSW_TOKEN below.

# ── Auth ─────────────────────────────────────────────────────────────────────
# Bearer token required on every API request (>= 8 chars; this one is 64).
CLSSW_TOKEN=ad62a448a822fba3d2e1b489942f6c75464d51004c4ee980b1b3219cf3e2bc36

# ── Network ──────────────────────────────────────────────────────────────────
# Loopback only — put nginx (or another reverse proxy) in front for TLS + auth.
HOST=127.0.0.1
PORT=8443

# ── Persistent data dir ──────────────────────────────────────────────────────
# SQLite DB and PTY log files. Put this on the disk you actually back up.
# Relative paths resolve against the server's working directory.
CLSSW_DATA=./data

# ── Storage backend ──────────────────────────────────────────────────────────
# STORAGE_KIND=sqlite (default) keeps a single file at CLSSW_DATA/clssw.db.
# For multi-host or backup-friendlier deployments, switch to MySQL or Postgres
# and uncomment the matching block below.

STORAGE_KIND=sqlite

# ── MySQL (used when STORAGE_KIND=mysql) ─────────────────────────────────────
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=tired_pc
# MYSQL_PASSWORD=
# MYSQL_DATABASE=tired_pc

# ── PostgreSQL (used when STORAGE_KIND=postgres) ─────────────────────────────
# POSTGRES_CONNECTION_STRING=postgres://tired_pc:secret@127.0.0.1:5432/tired_pc

# ── CORS ─────────────────────────────────────────────────────────────────────
# Pick ONE of the three modes below:
#
# (A) Off — same-origin via reverse proxy (nginx, Caddy, …).
#     Comment out CORS_ORIGIN, set CLSSW_STRICT_CORS=1:
# CLSSW_STRICT_CORS=1
#
# (B) Allowlist — only the explicit origins you list.
#     Use this when the SPA lives somewhere specific (recommended):
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5175,http://localhost:4173
#
# (C) Wildcard — echo back whatever Origin the browser asks for.
#     Dev convenience; do NOT use once you have real users:
# CLSSW_PERMISSIVE_CORS=1

# ── SSE / debugging ──────────────────────────────────────────────────────────
# Encoding used in the SSE `data:` payload of output events:
#   base64 (default) — standard transport, encode-on-wire
#   hex              — raw bytes as a lowercase hex string; useful for
#                      debugging with `curl -N` or for inspecting exotic
#                      bytes that the SPA doesn't decode cleanly.
#                      (Set this only when the SPA is OUT of the loop —
#                      the chat UI still expects base64.)
CLSSW_SSE_FORMAT=base64

# When set to 1, the server also logs a hex+ASCII dump of every input and
# output stream to its own pino log. Local debugging only.
# CLSSW_DEBUG_SSE=1

