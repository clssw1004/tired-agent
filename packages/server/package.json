{
  "name": "@tired-pc/server",
  "version": "0.1.0",
  "private": true,
  "description": "tired-pc server daemon — PTY session manager with pluggable storage",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "postinstall": "npm --prefix web install --no-audit --no-fund",
    "prebuild": "npm --prefix web install --no-audit --no-fund",
    "build": "npm run build:web && npm run build:server",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "node scripts/build-web.mjs",
    "dev:server": "tsx watch src/index.ts --",
    "dev:web": "node scripts/build-web.mjs --watch",
    "dev": "node scripts/build-web.mjs && tsx watch src/index.ts --",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx test/*.test.ts",
    "clean": "rm -rf dist data src/web/static web/node_modules"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "better-sqlite3": "^11.1.2",
    "esbuild": "^0.21.5",
    "fastify": "^4.28.1",
    "kysely": "^0.27.4",
    "mysql2": "^3.11.0",
    "node-pty": "^1.0.0",
    "pg": "^8.12.0",
    "pino": "^9.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.0",
    "typescript": "^5.4.5"
  }
}
