CLSSW_TOKEN=ad62a448a822fba3d2e1b489942f6c75464d51004c4ee980b1b3219cf3e2bc36
HOST=0.0.0.0
PORT=8443
CLSSW_DATA=./data
STORAGE_KIND=sqlite
# Permissive CORS for LAN dev — your phone reaches the server directly so the
# origin will be whatever http://<PC_IP>:5173 your phone sees. Wildcard is
# the simplest option; tighten when you actually deploy.
CLSSW_PERMISSIVE_CORS=1
# Optional: hex-dump every SSE byte to the server log — handy when tracing
# claude TUI sequences on a real phone session.
CLSSW_DEBUG_SSE=1