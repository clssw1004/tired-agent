{
  "name": "@tired-pc/agent",
  "version": "0.1.0",
  "private": true,
  "description": "tired-pc agent — PTY session executor (no web UI)",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts --",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist data"
  },
  "dependencies": {
    "@tired-pc/protocol": "*",
    "@fastify/cors": "^9.0.1",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "fastify": "^4.28.1",
    "kysely": "^0.27.4",
    "node-pty": "^1.0.0",
    "pino": "^9.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.14.10",
    "tsx": "^4.16.0",
    "typescript": "^5.4.5"
  }
}
