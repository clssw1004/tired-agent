{
  "name": "@tired-agent/agent",
  "version": "0.1.19",
  "description": "tired-agent agent — PTY session executor (no web UI). Run interactive CLI tools remotely.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clssw1004/tired-agent.git"
  },
  "bugs": {
    "url": "https://github.com/clssw1004/tired-agent/issues"
  },
  "homepage": "https://github.com/clssw1004/tired-agent#readme",
  "type": "module",
  "main": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "tired-agent": "./dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts --",
    "start": "node dist/cli.js start",
    "test": "node scripts/run-tests.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist data",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@tired-agent/protocol": "^0.1.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^4.28.1",
    "kysely": "^0.27.4",
    "node-pty": "^1.0.0",
    "pino": "^9.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.14.10",
    "tsx": "^4.16.0",
    "typescript": "^5.4.5"
  }
}
