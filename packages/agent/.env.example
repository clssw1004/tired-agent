# Bearer token. If empty, the agent auto-generates one on first start
# and writes it to ~/.tiredagent/.env. Re-runs reuse the saved value.
CLSSW_TOKEN=

# Network (defaults: PORT=8444, HOST=127.0.0.1 — 0.0.0.0 when --register is set)
HOST=
PORT=

# Data directory (default: ~/.tiredagent)
CLSSW_DATA=

# Logging (default: log to {CLSSW_DATA}/logs/agent.log, level=info)
CLSSW_LOG_DIR=
CLSSW_LOG_LEVEL=info

# Manager registration (if omitted, agent runs standalone)
CLSSW_AGENT_NAME=    # defaults to os.hostname()
CLSSW_REGISTER=      # base64({managerUrl}) from the
                     # onboarding page in the manager UI

# Debug
CLSSW_SSE_FORMAT=base64
CLSSW_DEBUG_SSE=0
