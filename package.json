{
  "name": "tired-pc",
  "version": "0.1.0",
  "private": true,
  "description": "tired-pc — remote persistent interactive session system. Let your home PC work overtime, even while you're out.",
  "workspaces": [
    "packages/protocol",
    "packages/agent",
    "packages/manager",
    "packages/web"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:protocol": "npm run build -w @tired-pc/protocol",
    "build:agent": "npm run build -w @tired-pc/agent",
    "build:manager": "npm run build -w @tired-pc/manager",
    "build:web": "npm run build -w @tired-pc/web",
    "dev:agent": "npm run dev -w @tired-pc/agent",
    "dev:manager": "npm run dev -w @tired-pc/manager",
    "dev:web": "npm run dev -w @tired-pc/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.21.5": true,
    "esbuild@0.28.1": true,
    "node-pty@1.1.0": true
  }
}