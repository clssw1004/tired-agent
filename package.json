{
  "name": "tired-agent",
  "version": "0.1.13",
  "private": true,
  "description": "tired-agent — remote persistent interactive session system. Let your home PC work overtime, even while you're out.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clssw1004/tired-agent.git"
  },
  "bugs": {
    "url": "https://github.com/clssw1004/tired-agent/issues"
  },
  "homepage": "https://github.com/clssw1004/tired-agent#readme",
  "workspaces": [
    "packages/protocol",
    "packages/agent",
    "packages/manager",
    "packages/web"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:protocol": "npm run build -w @tired-agent/protocol",
    "build:agent": "npm run build -w @tired-agent/agent",
    "build:manager": "npm run build -w @tired-agent/manager",
    "build:web": "npm run build -w @tired-agent/web",
    "dev:agent": "npm run dev -w @tired-agent/agent",
    "dev:manager": "npm run dev -w @tired-agent/manager",
    "dev:web": "npm run dev -w @tired-agent/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.21.5": true,
    "esbuild@0.28.1": true,
    "node-pty@1.1.0": true
  }
}
